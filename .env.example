# =============================================================================
# cmdcode — environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Required server secret — used to sign session tokens.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER reuse between environments (dev/staging/prod).
SECRET_KEY=

# Port the FastAPI server listens on
APP_PORT=8000

# Judge0 service URL (used by the server to run code)
JUDGE0_URL=http://judge0:2358

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# SQLAlchemy database URL
# SQLite (default):  sqlite:///./cmdcode.db
# Docker volume:     sqlite:////data/cmdcode.db
DATABASE_URL=sqlite:///./cmdcode.db

# How often (seconds) the server checks problems.json for changes
PROBLEM_RELOAD_INTERVAL=60

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------

# Internal URL the Next.js server uses to reach the API (server-side fetches)
API_URL=http://localhost:8000

# Public GitHub repo URL shown in the UI
NEXT_PUBLIC_GITHUB_URL=https://github.com/darichards10/cmdcode

# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

# Default server URL used by the cmdcode CLI
# Can be overridden per-user in ~/.cmdcode/config.json
CMDCODE_SERVER_URL=http://localhost:8000
